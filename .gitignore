# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# omc
.omc
status/

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Compiled binaries left in the repo root by `go build` without -o.
# Build outputs belong in bin/ (see Makefile) or a release artifact, not git.
/reverb
/basic
/semantic-cache
/stale-knowledge

# Accidental Node artifacts — this is a Go project. If Node tooling is
# ever added intentionally, remove these lines.
/package.json
/package-lock.json
/node_modules/

# env file
.env

# idea
.idea

# bin
bin/
bin/*

# Editor/IDE
 .idea/
 .vscode/
