{
  "name": "@reverb/client",
  "version": "0.1.0-rc.0",
  "description": "TypeScript / JavaScript client for Reverb, a semantic response cache for LLMs.",
  "license": "Apache-2.0",
  "author": "Reverb maintainers",
  "homepage": "https://github.com/nobelk/reverb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nobelk/reverb.git",
    "directory": "sdk/js"
  },
  "bugs": {
    "url": "https://github.com/nobelk/reverb/issues"
  },
  "keywords": [
    "llm",
    "cache",
    "semantic-cache",
    "openai",
    "anthropic",
    "edge",
    "cloudflare-workers"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint src test scripts --ext .ts,.mts,.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:node": "node scripts/smoke.mjs",
    "smoke:workers": "node --experimental-vm-modules scripts/smoke.workers.mjs",
    "prepublishOnly": "npm run build && npm run typecheck && npm test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240821.0",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "miniflare": "^3.20240821.0",
    "msw": "^2.4.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
