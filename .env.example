# Reverb Environment Variables
# Copy this file to .env and edit as needed.

# ─── Core Settings ───────────────────────────────────────────────
# Default TTL for cache entries (Go duration format)
# REVERB_DEFAULT_TTL=24h

# Cosine similarity threshold for semantic-tier hits (0.0–1.0)
# REVERB_SIMILARITY_THRESHOLD=0.95

# ─── Redis Store ─────────────────────────────────────────────────
# Set store.backend to "redis" in your config YAML to enable Redis.
# REVERB_REDIS_PASSWORD=

# ─── Embedding Provider ─────────────────────────────────────────
# API key for the OpenAI embedding provider.
# REVERB_EMBEDDING_API_KEY=sk-...

# ─── OpenTelemetry ───────────────────────────────────────────────
# Enable OpenTelemetry tracing export (true/1 to enable)
# REVERB_OTEL_ENABLED=false

# OTLP HTTP endpoint (e.g., localhost:4318)
# REVERB_OTEL_ENDPOINT=

# Service name reported to the tracing backend
# REVERB_OTEL_SERVICE_NAME=reverb

# Use insecure (non-TLS) connection to the collector (true/1)
# REVERB_OTEL_INSECURE=false

# ─── Authentication ──────────────────────────────────────────────
# Enable Bearer-token API key auth for HTTP and gRPC (true/1)
# When enabled, configure tenants and api_keys in the YAML config,
# or use REVERB_AUTH_API_KEY for a single-key "default" tenant.
# REVERB_AUTH_ENABLED=false

# Shorthand: enables auth and creates a "default" tenant with this key.
# Useful for simple single-tenant deployments.
# REVERB_AUTH_API_KEY=
